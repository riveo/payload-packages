{
  "name": "@riveo/payload-purge-cache-plugin",
  "version": "0.2.1",
  "description": "Payload Purge Cache Plugin",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./components": {
      "import": "./dist/exports/components.js",
      "types": "./dist/exports/components.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "payload",
    "cms",
    "plugin",
    "typescript",
    "react",
    "template",
    "cache"
  ],
  "scripts": {
    "prebuild": "mkdir -p dist/components && cp src/components/styles.scss dist/components/styles.scss",
    "build": "tsc",
    "build:types": "tsc --emitDeclarationOnly",
    "check": "pnpm run '/^check:.+/'",
    "check:types": "tsc --noEmit",
    "check:lint": "eslint .",
    "check:format": "prettier --check .",
    "format": "prettier . --write",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "prepublishOnly": "pnpm run check && pnpm run clean && pnpm run build"
  },
  "author": "Piotr Rzeczkowski <pr@riveolabs.com> (https://notesofdev.com/)",
  "homepage": "https://github.com/riveo/payload-packages",
  "peerDependencies": {
    "@payloadcms/next": "^3.0.0",
    "@payloadcms/ui": "^3.0.0",
    "next": "^15.4.11 || ^16.2.2",
    "payload": "^3.0.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@riveo/eslint-config": "^0.2.2",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.10.0+sha512.d615db246fe70f25dcfea6d8d73dee782ce23e2245e3c4f6f888249fb568149318637dca73c2c5c8ef2a4ca0d5657fb9567188bfab47f566d1ee6ce987815c39",
  "dependencies": {
    "zod": "^4.4.3"
  }
}
